#!/usr/bin/env bash
set -euo pipefail

IMAGE="${AI_SANDBOX_IMAGE:-ai-sandbox-vscode}"
HOME_STORAGE="${AI_SANDBOX_HOME_STORAGE:-${AI_SANDBOX_HOME_VOLUME:-$HOME/.cache/ai-sandbox/home}}"
NIX_STORAGE="${AI_SANDBOX_NIX_STORAGE:-${AI_SANDBOX_NIX_VOLUME:-$HOME/.cache/ai-sandbox/nix}}"
BUILD_CONTEXT="${AI_SANDBOX_BUILD_CONTEXT:-}"
STATE_DIR="${AI_SANDBOX_STATE_DIR:-$HOME/.local/state/ai-sandbox}"
NETWORK_MODE="${AI_SANDBOX_NETWORK_MODE:-host}"

mkdir -p "$STATE_DIR"

if [[ -z "$BUILD_CONTEXT" || ! -d "$BUILD_CONTEXT" ]]; then
  echo "AI_SANDBOX_BUILD_CONTEXT is not set or invalid." >&2
  exit 1
fi

usage() {
  cat <<'EOF'
Usage:
  ai-sandbox [start] [WORKSPACE] [--flake PATH] [--network host|bridge] [--instance NAME] [--logs]
  ai-sandbox shell [WORKSPACE] [--flake PATH] [--network host|bridge] [--instance NAME]
  ai-sandbox warm [WORKSPACE] [--flake PATH] [--network host|bridge] [--instance NAME]
  ai-sandbox exec [WORKSPACE] [--flake PATH] [--network host|bridge] [--instance NAME] -- COMMAND [ARGS...]
  ai-sandbox install [WORKSPACE] [--force] [--only all|codex|vscode]
  ai-sandbox build [WORKSPACE] [--force] [--only all|codex|vscode]
  ai-sandbox logs [WORKSPACE] [-f|--follow]
  ai-sandbox open-url URL
  ai-sandbox open-in-editor FILE [LINE] [COLUMN]
  ai-sandbox repair-nix
  ai-sandbox build-base
  ai-sandbox rebuild
  ai-sandbox reset-storage
  ai-sandbox reset-volumes  # alias for reset-storage
  ai-sandbox help
EOF
}

follow_startup_logs_until_vscode() {
  local container="$1"
  local marker="AI_SANDBOX_READY_VSCODE:"
  echo "Streaming startup logs until VS Code launches..."
  (
    set +e
    set +o pipefail
    podman logs -f "$container" 2>&1 | awk -v marker="$marker" '
      { print; fflush(); if (index($0, marker)) exit 0 }
    '
  ) || true
}

ensure_vscode_url_handler() {
  local desktop_dir desktop_file ai_sandbox_cmd
  desktop_dir="${XDG_DATA_HOME:-$HOME/.local/share}/applications"
  desktop_file="$desktop_dir/ai-sandbox-vscode-url-handler.desktop"

  ai_sandbox_cmd="$(command -v ai-sandbox || true)"
  if [[ -z "$ai_sandbox_cmd" ]]; then
    ai_sandbox_cmd="$(realpath "$0")"
  fi

  mkdir -p "$desktop_dir"
  cat > "$desktop_file" <<EOF
[Desktop Entry]
Name=AI Sandbox VS Code URL Handler
Exec=$ai_sandbox_cmd open-url %u
Terminal=false
Type=Application
MimeType=x-scheme-handler/vscode;x-scheme-handler/vscode-insiders;
Categories=Development;
NoDisplay=true
EOF

  if command -v xdg-mime >/dev/null 2>&1; then
    xdg-mime default ai-sandbox-vscode-url-handler.desktop x-scheme-handler/vscode >/dev/null 2>&1 || true
    xdg-mime default ai-sandbox-vscode-url-handler.desktop x-scheme-handler/vscode-insiders >/dev/null 2>&1 || true
  fi

  if command -v xdg-settings >/dev/null 2>&1; then
    xdg-settings set default-url-scheme-handler vscode ai-sandbox-vscode-url-handler.desktop >/dev/null 2>&1 || true
    xdg-settings set default-url-scheme-handler vscode-insiders ai-sandbox-vscode-url-handler.desktop >/dev/null 2>&1 || true
  fi

  if command -v gio >/dev/null 2>&1; then
    gio mime x-scheme-handler/vscode ai-sandbox-vscode-url-handler.desktop >/dev/null 2>&1 || true
    gio mime x-scheme-handler/vscode-insiders ai-sandbox-vscode-url-handler.desktop >/dev/null 2>&1 || true
  fi
}

detect_theme() {
  local scheme=""
  if command -v kreadconfig5 >/dev/null 2>&1; then
    scheme="$(kreadconfig5 --file "$HOME/.config/kdeglobals" --group General --key ColorScheme 2>/dev/null || true)"
  fi
  if [[ -z "$scheme" && -f "$HOME/.config/kdeglobals" ]]; then
    scheme="$(grep -E '^ColorScheme=' "$HOME/.config/kdeglobals" | head -n1 | cut -d= -f2- || true)"
  fi

  case "${scheme,,}" in
    *dark*|*black*|*night*) echo "dark" ;;
    *) echo "light" ;;
  esac
}

pick_running_container() {
  if [[ -f "$STATE_DIR/last-container" ]]; then
    local c
    c="$(cat "$STATE_DIR/last-container" 2>/dev/null || true)"
    if [[ -n "$c" ]] && podman inspect "$c" >/dev/null 2>&1; then
      if [[ "$(podman inspect -f '{{.State.Running}}' "$c" 2>/dev/null || true)" == "true" ]]; then
        echo "$c"
        return 0
      fi
    fi
  fi

  podman ps --filter label=ai-sandbox=true --format '{{.Names}}' | head -n1
}

pick_running_container_for_workspace() {
  local workspace_path="$1"

  podman ps \
    --filter label=ai-sandbox=true \
    --filter "label=ai-sandbox.workspace=$workspace_path" \
    --format '{{.Names}}' | head -n1
}

pick_running_container_for_file() {
  local file_path="$1"
  local best_name=""
  local best_len=0
  local name ws ws_len

  while IFS=$'\t' read -r name ws; do
    [[ -n "$name" && -n "$ws" ]] || continue

    if [[ "$file_path" == "$ws" || "$file_path" == "$ws/"* ]]; then
      ws_len="${#ws}"
      if (( ws_len > best_len )); then
        best_len="$ws_len"
        best_name="$name"
      fi
    fi
  done < <(
    podman ps \
      --filter label=ai-sandbox=true \
      --format '{{.Names}}	{{.Label "ai-sandbox.workspace"}}'
  )

  if [[ -n "$best_name" ]]; then
    echo "$best_name"
    return 0
  fi

  return 1
}

map_host_target_for_container() {
  local container="$1"
  local target="$2"
  local path_part="$target"
  local line_part=""
  local col_part=""
  local host_root=""
  local container_root=""
  local mapped_path=""
  local env_dump

  if [[ "$target" =~ ^(.+):([0-9]+):([0-9]+)$ ]]; then
    path_part="${BASH_REMATCH[1]}"
    line_part="${BASH_REMATCH[2]}"
    col_part="${BASH_REMATCH[3]}"
  elif [[ "$target" =~ ^(.+):([0-9]+)$ ]]; then
    path_part="${BASH_REMATCH[1]}"
    line_part="${BASH_REMATCH[2]}"
  fi

  env_dump="$(podman inspect -f '{{range .Config.Env}}{{println .}}{{end}}' "$container" 2>/dev/null || true)"
  host_root="$(printf '%s\n' "$env_dump" | sed -n 's/^AI_SANDBOX_HOST_MOUNT_ROOT=//p' | head -n1)"
  container_root="$(printf '%s\n' "$env_dump" | sed -n 's/^AI_SANDBOX_CONTAINER_MOUNT_ROOT=//p' | head -n1)"
  [[ -n "$container_root" ]] || container_root="/workspace"

  mapped_path="$path_part"
  if [[ -n "$host_root" ]]; then
    if [[ "$path_part" == "$host_root" ]]; then
      mapped_path="$container_root"
    elif [[ "$path_part" == "$host_root/"* ]]; then
      mapped_path="$container_root/${path_part#"$host_root"/}"
    fi
  fi

  if [[ -n "$line_part" && -n "$col_part" ]]; then
    printf '%s:%s:%s\n' "$mapped_path" "$line_part" "$col_part"
    return 0
  fi
  if [[ -n "$line_part" ]]; then
    printf '%s:%s\n' "$mapped_path" "$line_part"
    return 0
  fi
  printf '%s\n' "$mapped_path"
}

sanitize_instance_name() {
  local raw="$1"
  local cleaned
  cleaned="$(echo -n "$raw" | tr '[:upper:]' '[:lower:]' | tr -cs 'a-z0-9_.-' '-')"
  cleaned="${cleaned#-}"
  cleaned="${cleaned%-}"

  if [[ -z "$cleaned" ]]; then
    echo "Invalid --instance value: '$raw' (expected letters, numbers, ., _, -)" >&2
    exit 1
  fi

  echo "$cleaned"
}

sanitize_container_name_part() {
  local raw="$1"
  local fallback="$2"
  local cleaned
  cleaned="$(echo -n "$raw" | tr '[:upper:]' '[:lower:]' | tr -cs 'a-z0-9_.-' '-')"
  cleaned="${cleaned#-}"
  cleaned="${cleaned%-}"
  cleaned="${cleaned:0:32}"

  if [[ -z "$cleaned" ]]; then
    echo "$fallback"
    return
  fi

  echo "$cleaned"
}

pick_auto_instance_name() {
  local base_name="$1"
  local preferred="default"
  local preferred_container="${base_name}-${preferred}"

  # Reuse a stable default instance name for persistent VS Code profile state.
  # If that container name is already in use (e.g. another live session), fall
  # back to a unique instance suffix.
  if podman inspect "$preferred_container" >/dev/null 2>&1; then
    local rand_suffix
    rand_suffix="$(od -An -N3 -tx1 /dev/urandom | tr -d ' \n')"
    echo "${preferred}-$(date +%Y%m%d-%H%M%S)-${rand_suffix}"
    return
  fi

  echo "$preferred"
}

cmd="start"
workspace="$PWD"
flake_arg=""
open_url_arg=""
open_editor_file=""
open_editor_line=""
open_editor_col=""
instance_arg=""
follow_logs_on_start=0
logs_follow=0
exec_command=()
workspace_explicit=0
install_force=0
install_only="all"

if [[ $# -gt 0 ]]; then
  case "$1" in
    start|shell|warm|exec|install|build|logs|build-base|rebuild|reset-storage|reset-volumes|repair-nix|open-url|open-in-editor|help|-h|--help)
      cmd="$1"
      shift
      ;;
    *)
      cmd="start"
      ;;
  esac
fi

while [[ $# -gt 0 ]]; do
  case "$1" in
    --)
      shift
      if [[ "$cmd" == "exec" ]]; then
        exec_command=("$@")
        break
      fi
      ;;
    --force)
      if [[ "$cmd" == "install" || "$cmd" == "build" ]]; then
        install_force=1
        shift
        continue
      fi
      echo "--force is only valid with install/build" >&2
      exit 1
      ;;
    --only)
      if [[ "$cmd" == "install" || "$cmd" == "build" ]]; then
        shift
        [[ $# -gt 0 ]] || { echo "--only requires all|codex|vscode" >&2; exit 1; }
        install_only="$1"
        shift
        continue
      fi
      echo "--only is only valid with install/build" >&2
      exit 1
      ;;
    --flake)
      shift
      [[ $# -gt 0 ]] || { echo "--flake requires a path" >&2; exit 1; }
      flake_arg="$(realpath "$1")"
      shift
      ;;
    --network)
      shift
      [[ $# -gt 0 ]] || { echo "--network requires host or bridge" >&2; exit 1; }
      NETWORK_MODE="$1"
      shift
      ;;
    --instance)
      shift
      [[ $# -gt 0 ]] || { echo "--instance requires a name" >&2; exit 1; }
      instance_arg="$(sanitize_instance_name "$1")"
      shift
      ;;
    --logs)
      follow_logs_on_start=1
      shift
      ;;
    -f|--follow)
      logs_follow=1
      shift
      ;;
    *)
      if [[ "$cmd" == "exec" ]]; then
        if [[ "$workspace_explicit" -eq 0 && -d "$1" ]]; then
          workspace="$(realpath "$1")"
          workspace_explicit=1
          shift
          continue
        fi
        exec_command=("$@")
        break
      elif [[ "$cmd" == "open-url" && -z "$open_url_arg" ]]; then
        open_url_arg="$1"
      elif [[ "$cmd" == "open-in-editor" ]]; then
        if [[ -z "$open_editor_file" ]]; then
          if [[ "$1" == /* ]]; then
            open_editor_file="$1"
          else
            open_editor_file="$(realpath -m "$1")"
          fi
        elif [[ -z "$open_editor_line" ]]; then
          open_editor_line="$1"
        elif [[ -z "$open_editor_col" ]]; then
          open_editor_col="$1"
        else
          echo "open-in-editor accepts at most FILE [LINE] [COLUMN]" >&2
          exit 1
        fi
      else
        workspace="$(realpath "$1")"
      fi
      shift
      ;;
  esac
done

if [[ "$cmd" == "exec" && ${#exec_command[@]} -eq 0 ]]; then
  echo "exec requires a command. Example: ai-sandbox exec -- codex --version" >&2
  exit 2
fi

case "$install_only" in
  all|codex|vscode) ;;
  *)
    echo "Invalid --only value: $install_only (expected all|codex|vscode)" >&2
    exit 1
    ;;
esac

case "$NETWORK_MODE" in
  host|bridge) ;;
  *)
    echo "Invalid network mode: $NETWORK_MODE (expected host or bridge)" >&2
    exit 1
    ;;
esac

if [[ "$cmd" == "start" || "$cmd" == "shell" || "$cmd" == "warm" ]]; then
  ensure_vscode_url_handler
fi

if [[ "$cmd" != "logs" ]] && [[ "$logs_follow" -eq 1 ]]; then
  echo "-f/--follow is only valid with the logs command." >&2
  exit 1
fi

case "$cmd" in
  help|-h|--help)
    usage
    exit 0
    ;;
  build-base)
    podman build -t "$IMAGE" -f "$BUILD_CONTEXT/Dockerfile" "$BUILD_CONTEXT"
    exit 0
    ;;
  build)
    podman build -t "$IMAGE" -f "$BUILD_CONTEXT/Dockerfile" "$BUILD_CONTEXT"
    cmd="install"
    ;;
  rebuild)
    if podman image exists "$IMAGE"; then
      podman rmi -f "$IMAGE" >/dev/null
    fi
    podman build -t "$IMAGE" -f "$BUILD_CONTEXT/Dockerfile" "$BUILD_CONTEXT"
    exit 0
    ;;
  logs)
    if [[ -n "${workspace:-}" && -d "$workspace" ]]; then
      workspace="$(realpath "$workspace")"
      target_container="$(pick_running_container_for_workspace "$workspace")"
      [[ -n "${target_container:-}" ]] || target_container="$(pick_running_container)"
    else
      target_container="$(pick_running_container)"
    fi

    [[ -n "${target_container:-}" ]] || { echo "No AI sandbox container found." >&2; exit 1; }
    if [[ "$logs_follow" -eq 1 ]]; then
      exec podman logs -f "$target_container"
    else
      exec podman logs "$target_container"
    fi
    ;;
  reset-storage|reset-volumes)
    # Stop/remove running AI sandbox containers first so storage can be removed.
    mapfile -t sandbox_containers < <(podman ps -aq --filter label=ai-sandbox=true)
    if [[ ${#sandbox_containers[@]} -gt 0 ]]; then
      podman rm -f "${sandbox_containers[@]}" >/dev/null
    fi

    for storage in "$NIX_STORAGE" "$HOME_STORAGE"; do
      if [[ "$storage" == /* ]]; then
        case "$storage" in
          "/"|"")
            echo "Refusing to reset unsafe storage path: $storage" >&2
            exit 1
            ;;
        esac
        rm -rf -- "$storage"
        mkdir -p -- "$storage"
      else
        if podman volume exists "$storage"; then
          podman volume rm -f "$storage" >/dev/null
        fi
      fi
    done

    echo "Reset storage: $NIX_STORAGE, $HOME_STORAGE"
    exit 0
    ;;
  repair-nix)
    home_mount_spec=""
    nix_mount_spec=""
    if [[ "$HOME_STORAGE" == /* ]]; then
      mkdir -p "$HOME_STORAGE"
      home_mount_spec="$HOME_STORAGE:/sandbox-home:Z"
    else
      home_mount_spec="$HOME_STORAGE:/sandbox-home:Z,U"
    fi

    if [[ "$NIX_STORAGE" == /* ]]; then
      mkdir -p "$NIX_STORAGE"
      nix_mount_spec="$NIX_STORAGE:/nix:Z"
    else
      nix_mount_spec="$NIX_STORAGE:/nix:Z,U"
    fi

    exec podman run --rm -it \
      --userns=keep-id \
      --user "$(id -u):$(id -g)" \
      --group-add keep-groups \
      -e HOME=/sandbox-home \
      -e XDG_RUNTIME_DIR=/tmp/xdg-runtime \
      -e AI_SANDBOX_MODE=repair \
      -v "$home_mount_spec" \
      -v "$nix_mount_spec" \
      "$IMAGE"
    ;;
  open-url)
    [[ -n "$open_url_arg" ]] || { echo "open-url requires a URL" >&2; exit 1; }
    container="$(pick_running_container)"
    if [[ -n "$container" ]]; then
      exec podman exec "$container" /usr/local/bin/ai-sandbox-open-url "$open_url_arg"
    fi
    exec code --open-url "$open_url_arg"
    echo "No running AI sandbox container found, and host VS Code failed to handle --open-url." >&2
    exit 1
    ;;
  open-in-editor)
    [[ -n "$open_editor_file" ]] || { echo "open-in-editor requires FILE [LINE] [COLUMN]" >&2; exit 1; }
    if ! [[ -z "$open_editor_line" || "$open_editor_line" =~ ^[0-9]+$ ]]; then
      echo "LINE must be numeric: $open_editor_line" >&2
      exit 1
    fi
    if ! [[ -z "$open_editor_col" || "$open_editor_col" =~ ^[0-9]+$ ]]; then
      echo "COLUMN must be numeric: $open_editor_col" >&2
      exit 1
    fi

    target="$open_editor_file"
    if [[ -n "$open_editor_line" && -n "$open_editor_col" ]]; then
      target="${target}:${open_editor_line}:${open_editor_col}"
    elif [[ -n "$open_editor_line" ]]; then
      target="${target}:${open_editor_line}"
    fi

    container="$(pick_running_container_for_file "$open_editor_file" || true)"
    [[ -n "$container" ]] || container="$(pick_running_container)"
    if [[ -n "$container" ]]; then
      target="$(map_host_target_for_container "$container" "$target")"
      exec podman exec "$container" bash -lc '
        editor_bin="$(command -v code || true)"
        if [[ -z "$editor_bin" ]]; then
          echo "No VS Code binary found inside sandbox container." >&2
          exit 127
        fi

        exec "$editor_bin" \
          --user-data-dir "${AI_SANDBOX_VSCODE_USER_DATA_DIR:-/sandbox-home/.vscode-data}" \
          --extensions-dir "${AI_SANDBOX_VSCODE_EXTENSIONS_DIR:-/sandbox-home/.vscode-extensions}" \
          --goto "$1"
      ' _ "$target"
    fi

    exec code --goto "$target"
    ;;
esac

[[ -d "$workspace" ]] || { echo "Workspace does not exist: $workspace" >&2; exit 1; }
project_name="$(basename "$workspace")"

home_mount_spec=""
nix_mount_spec=""
if [[ "$HOME_STORAGE" == /* ]]; then
  mkdir -p "$HOME_STORAGE"
  home_mount_spec="$HOME_STORAGE:/sandbox-home:Z"
else
  home_mount_spec="$HOME_STORAGE:/sandbox-home:Z,U"
fi

if [[ "$NIX_STORAGE" == /* ]]; then
  mkdir -p "$NIX_STORAGE"
  nix_mount_spec="$NIX_STORAGE:/nix:Z"
else
  nix_mount_spec="$NIX_STORAGE:/nix:Z,U"
fi

mount_root="$workspace"
container_workspace="/workspace"

# Preserve parent directory depth for submodule workspaces by mounting the top
# superproject root and opening the requested workspace path underneath it.
if command -v git >/dev/null 2>&1 && git -C "$workspace" rev-parse --is-inside-work-tree >/dev/null 2>&1; then
  probe="$workspace"
  while true; do
    superproject="$(git -C "$probe" rev-parse --show-superproject-working-tree 2>/dev/null || true)"
    [[ -n "$superproject" ]] || break
    probe="$(realpath "$superproject")"
  done

  if [[ "$probe" != "$workspace" ]]; then
    mount_root="$probe"
    workspace_rel="$(realpath --relative-to="$mount_root" "$workspace")"
    container_workspace="/workspace/$workspace_rel"
  fi
fi

flake_arg_container="${flake_arg:-}"
if [[ -n "${flake_arg:-}" ]]; then
  if [[ "$flake_arg" == "$mount_root" || "$flake_arg" == "$mount_root/"* ]]; then
    flake_rel="$(realpath --relative-to="$mount_root" "$flake_arg")"
    if [[ "$flake_rel" == "." ]]; then
      flake_arg_container="/workspace"
    else
      flake_arg_container="/workspace/$flake_rel"
    fi
  fi
fi

workspace_hash="$(echo -n "$workspace" | sha256sum | cut -c1-12)"
project_slug="$(sanitize_container_name_part "$project_name" "workspace")"
launch_context="vscode"
if [[ "$cmd" == "shell" || "$cmd" == "warm" || "$cmd" == "exec" ]]; then
  launch_context="shell"
fi
base_container_name="ai-sandbox-${project_slug}-${launch_context}-${workspace_hash}"
if [[ -n "$instance_arg" ]]; then
  container_name="$base_container_name-$instance_arg"
else
  auto_instance="$(pick_auto_instance_name "$base_container_name")"
  container_name="$base_container_name-$auto_instance"
  instance_arg="$auto_instance"
fi

echo "$container_name" > "$STATE_DIR/last-container"

# Keep process/cache/webview data per instance to avoid Chromium profile
# collisions, while sharing user-level settings/extensions for a desktop-like
# experience across sandbox instances.
vscode_profile_id="${workspace_hash}-${instance_arg}"
vscode_user_data_dir="/sandbox-home/.vscode-data/instances/$vscode_profile_id"
vscode_extensions_dir="/sandbox-home/.vscode-extensions/shared"
vscode_shared_user_dir="/sandbox-home/.vscode-shared-user"

theme="$(detect_theme)"

dbus_args=()
x11_args=()
if [[ "$cmd" != "install" ]]; then
  xauth_file="${XAUTHORITY:-$HOME/.Xauthority}"
  [[ -f "$xauth_file" ]] || { echo "Xauthority file not found: $xauth_file" >&2; exit 1; }

  x11_args=(
    -e "DISPLAY=${DISPLAY:-:0}"
    -e XAUTHORITY=/tmp/.Xauthority
    -v /tmp/.X11-unix:/tmp/.X11-unix:ro
    -v "$xauth_file:/tmp/.Xauthority:ro"
    --device /dev/dri
  )

  if [[ -n "${XDG_RUNTIME_DIR:-}" && -S "${XDG_RUNTIME_DIR}/bus" ]]; then
    dbus_args=(
      -e "DBUS_SESSION_BUS_ADDRESS=unix:path=/host-run-user-bus"
      -v "${XDG_RUNTIME_DIR}/bus:/host-run-user-bus:rw"
    )
  fi
fi

common_args=(
  --name "$container_name"
  --init
  --userns=keep-id
  --user "$(id -u):$(id -g)"
  --group-add keep-groups
  --label ai-sandbox=true
  --label "ai-sandbox.workspace=$workspace"
  --label "ai-sandbox.workspace-hash=$workspace_hash"
  --label "ai-sandbox.instance=$instance_arg"
  -e HOME=/sandbox-home
  -e XDG_RUNTIME_DIR=/tmp/xdg-runtime
  -e "AI_SANDBOX_MODE=$cmd"
  -e "AI_SANDBOX_FLAKE=$flake_arg_container"
  -e "AI_SANDBOX_WORKSPACE=$container_workspace"
  -e "AI_SANDBOX_HOST_MOUNT_ROOT=$mount_root"
  -e "AI_SANDBOX_CONTAINER_MOUNT_ROOT=/workspace"
  -e "AI_SANDBOX_PROJECT_NAME=$project_name"
  -e "AI_SANDBOX_INSTANCE_NAME=$instance_arg"
  -e "AI_SANDBOX_THEME=$theme"
  -e "AI_SANDBOX_VSCODE_USER_DATA_DIR=$vscode_user_data_dir"
  -e "AI_SANDBOX_VSCODE_EXTENSIONS_DIR=$vscode_extensions_dir"
  -e "AI_SANDBOX_VSCODE_SHARED_USER_DIR=$vscode_shared_user_dir"
  -v "$mount_root:/workspace:Z"
  -v "$home_mount_spec"
  -v "$nix_mount_spec"
  "${x11_args[@]}"
)

network_args=()
if [[ "$NETWORK_MODE" == "host" ]]; then
  network_args=(--network host)
fi

run_detached() {
  echo "Starting sandbox container $container_name..."
  podman run --rm -d \
    "${common_args[@]}" \
    "${network_args[@]}" \
    "${dbus_args[@]}" \
    "$IMAGE" >/dev/null
  echo "Started $container_name"
  follow_startup_logs_until_vscode "$container_name"
  if [[ "$follow_logs_on_start" -eq 1 ]]; then
    echo "Continuing to follow logs for $container_name (Ctrl-C to stop following; container keeps running)..."
    podman logs -f --tail 0 "$container_name"
  fi
}

run_interactive() {
  echo "Starting interactive sandbox container $container_name..."
  podman run --rm -it \
    "${common_args[@]}" \
    "${network_args[@]}" \
    "${dbus_args[@]}" \
    "$IMAGE"
}

run_exec() {
  local existing_container existing_workspace env_dump

  existing_container="$(pick_running_container_for_workspace "$workspace" || true)"
  if [[ -n "$existing_container" ]]; then
    echo "Reusing running sandbox container $existing_container..."
    env_dump="$(podman inspect -f '{{range .Config.Env}}{{println .}}{{end}}' "$existing_container" 2>/dev/null || true)"
    existing_workspace="$(printf '%s\n' "$env_dump" | sed -n 's/^AI_SANDBOX_WORKSPACE=//p' | head -n1)"
    [[ -n "$existing_workspace" ]] || existing_workspace="/workspace"
    echo "Running command in sandbox workspace $existing_workspace: ${exec_command[*]}"
    exec podman exec -it "$existing_container" /bin/bash -lc 'cd "$1"; shift; exec "$@"' _ "$existing_workspace" "${exec_command[@]}"
  fi

  echo "No running sandbox found for workspace; starting temporary container..."
  echo "Running command: ${exec_command[*]}"
  exec podman run --rm -it \
    "${common_args[@]}" \
    "${network_args[@]}" \
    "${dbus_args[@]}" \
    "$IMAGE" "${exec_command[@]}"
}

run_install() {
  local existing_container install_args=()
  if [[ "$install_force" -eq 1 ]]; then
    install_args+=(--force)
  fi
  install_args+=(--only "$install_only")

  existing_container="$(pick_running_container_for_workspace "$workspace" || true)"
  if [[ -n "$existing_container" ]]; then
    echo "Reusing running sandbox container $existing_container for software install..."
    echo "Install options: ${install_args[*]}"
    exec podman exec -it "$existing_container" /usr/local/bin/ai-sandbox-default-install "${install_args[@]}"
  fi

  echo "No running sandbox found for workspace; starting temporary container for install..."
  echo "Install options: ${install_args[*]}"
  exec podman run --rm -it \
    "${common_args[@]}" \
    "${network_args[@]}" \
    "${dbus_args[@]}" \
    -e AI_SANDBOX_MODE=exec \
    "$IMAGE" /usr/local/bin/ai-sandbox-default-install "${install_args[@]}"
}

case "$cmd" in
  start) run_detached ;;
  shell|warm) run_interactive ;;
  exec) run_exec ;;
  install) run_install ;;
  *) usage >&2; exit 1 ;;
esac
