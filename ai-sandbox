#!/usr/bin/env bash
set -euo pipefail

IMAGE="${AI_SANDBOX_IMAGE:-ai-sandbox-vscode}"
HOME_VOLUME="${AI_SANDBOX_HOME_VOLUME:-ai-sandbox-home}"
NIX_VOLUME="${AI_SANDBOX_NIX_VOLUME:-ai-sandbox-nix}"
BUILD_CONTEXT="${AI_SANDBOX_BUILD_CONTEXT:-}"
STATE_DIR="${AI_SANDBOX_STATE_DIR:-$HOME/.local/state/ai-sandbox}"
NETWORK_MODE="${AI_SANDBOX_NETWORK_MODE:-host}"

mkdir -p "$STATE_DIR"

if [[ -z "$BUILD_CONTEXT" || ! -d "$BUILD_CONTEXT" ]]; then
  echo "AI_SANDBOX_BUILD_CONTEXT is not set or invalid." >&2
  exit 1
fi

usage() {
  cat <<'EOF'
Usage:
  ai-sandbox [start] [WORKSPACE] [--flake PATH] [--network host|bridge]
  ai-sandbox shell [WORKSPACE] [--flake PATH] [--network host|bridge]
  ai-sandbox warm [WORKSPACE] [--flake PATH] [--network host|bridge]
  ai-sandbox open-url URL
  ai-sandbox build-base
  ai-sandbox help
EOF
}

ensure_vscode_url_handler() {
  local desktop_dir desktop_file ai_sandbox_cmd
  desktop_dir="${XDG_DATA_HOME:-$HOME/.local/share}/applications"
  desktop_file="$desktop_dir/ai-sandbox-vscode-url-handler.desktop"

  ai_sandbox_cmd="$(command -v ai-sandbox || true)"
  if [[ -z "$ai_sandbox_cmd" ]]; then
    ai_sandbox_cmd="$(realpath "$0")"
  fi

  mkdir -p "$desktop_dir"
  cat > "$desktop_file" <<EOF
[Desktop Entry]
Name=AI Sandbox VS Code URL Handler
Exec=$ai_sandbox_cmd open-url %u
Terminal=false
Type=Application
MimeType=x-scheme-handler/vscode;x-scheme-handler/vscode-insiders;
Categories=Development;
NoDisplay=true
EOF

  if command -v xdg-mime >/dev/null 2>&1; then
    xdg-mime default ai-sandbox-vscode-url-handler.desktop x-scheme-handler/vscode >/dev/null 2>&1 || true
    xdg-mime default ai-sandbox-vscode-url-handler.desktop x-scheme-handler/vscode-insiders >/dev/null 2>&1 || true
  fi

  if command -v xdg-settings >/dev/null 2>&1; then
    xdg-settings set default-url-scheme-handler vscode ai-sandbox-vscode-url-handler.desktop >/dev/null 2>&1 || true
    xdg-settings set default-url-scheme-handler vscode-insiders ai-sandbox-vscode-url-handler.desktop >/dev/null 2>&1 || true
  fi

  if command -v gio >/dev/null 2>&1; then
    gio mime x-scheme-handler/vscode ai-sandbox-vscode-url-handler.desktop >/dev/null 2>&1 || true
    gio mime x-scheme-handler/vscode-insiders ai-sandbox-vscode-url-handler.desktop >/dev/null 2>&1 || true
  fi
}

detect_theme() {
  local scheme=""
  if command -v kreadconfig5 >/dev/null 2>&1; then
    scheme="$(kreadconfig5 --file "$HOME/.config/kdeglobals" --group General --key ColorScheme 2>/dev/null || true)"
  fi
  if [[ -z "$scheme" && -f "$HOME/.config/kdeglobals" ]]; then
    scheme="$(grep -E '^ColorScheme=' "$HOME/.config/kdeglobals" | head -n1 | cut -d= -f2- || true)"
  fi

  case "${scheme,,}" in
    *dark*|*black*|*night*) echo "dark" ;;
    *) echo "light" ;;
  esac
}

pick_running_container() {
  if [[ -f "$STATE_DIR/last-container" ]]; then
    local c
    c="$(cat "$STATE_DIR/last-container" 2>/dev/null || true)"
    if [[ -n "$c" ]] && podman inspect "$c" >/dev/null 2>&1; then
      if [[ "$(podman inspect -f '{{.State.Running}}' "$c" 2>/dev/null || true)" == "true" ]]; then
        echo "$c"
        return 0
      fi
    fi
  fi

  podman ps --filter label=ai-sandbox=true --format '{{.Names}}' | tail -n1
}

cmd="start"
workspace="$PWD"
flake_arg=""
open_url_arg=""

if [[ $# -gt 0 ]]; then
  case "$1" in
    start|shell|warm|build-base|open-url|help|-h|--help)
      cmd="$1"
      shift
      ;;
    *)
      cmd="start"
      ;;
  esac
fi

while [[ $# -gt 0 ]]; do
  case "$1" in
    --flake)
      shift
      [[ $# -gt 0 ]] || { echo "--flake requires a path" >&2; exit 1; }
      flake_arg="$(realpath "$1")"
      shift
      ;;
    --network)
      shift
      [[ $# -gt 0 ]] || { echo "--network requires host or bridge" >&2; exit 1; }
      NETWORK_MODE="$1"
      shift
      ;;
    *)
      if [[ "$cmd" == "open-url" && -z "$open_url_arg" ]]; then
        open_url_arg="$1"
      else
        workspace="$(realpath "$1")"
      fi
      shift
      ;;
  esac
done

case "$NETWORK_MODE" in
  host|bridge) ;;
  *)
    echo "Invalid network mode: $NETWORK_MODE (expected host or bridge)" >&2
    exit 1
    ;;
esac

if [[ "$cmd" == "start" || "$cmd" == "shell" || "$cmd" == "warm" ]]; then
  ensure_vscode_url_handler
fi

case "$cmd" in
  help|-h|--help)
    usage
    exit 0
    ;;
  build-base)
    podman build -t "$IMAGE" -f "$BUILD_CONTEXT/Dockerfile" "$BUILD_CONTEXT"
    exit 0
    ;;
  open-url)
    [[ -n "$open_url_arg" ]] || { echo "open-url requires a URL" >&2; exit 1; }
    container="$(pick_running_container)"
    if [[ -n "$container" ]]; then
      exec podman exec "$container" /usr/local/bin/ai-sandbox-open-url "$open_url_arg"
    fi
    exec code --open-url "$open_url_arg"
    echo "No running AI sandbox container found, and host VS Code failed to handle --open-url." >&2
    exit 1
    ;;
esac

[[ -d "$workspace" ]] || { echo "Workspace does not exist: $workspace" >&2; exit 1; }

container_name="ai-sandbox-$(echo -n "$workspace" | sha256sum | cut -c1-12)"
echo "$container_name" > "$STATE_DIR/last-container"

xauth_file="${XAUTHORITY:-$HOME/.Xauthority}"
[[ -f "$xauth_file" ]] || { echo "Xauthority file not found: $xauth_file" >&2; exit 1; }

theme="$(detect_theme)"

dbus_args=()
if [[ -n "${XDG_RUNTIME_DIR:-}" && -S "${XDG_RUNTIME_DIR}/bus" ]]; then
  dbus_args=(
    -e "DBUS_SESSION_BUS_ADDRESS=unix:path=/host-run-user-bus"
    -v "${XDG_RUNTIME_DIR}/bus:/host-run-user-bus:rw"
  )
fi

common_args=(
  --name "$container_name"
  --userns=keep-id
  --user "$(id -u):$(id -g)"
  --group-add keep-groups
  --label ai-sandbox=true
  --label "ai-sandbox.workspace=$workspace"
  -e "DISPLAY=${DISPLAY:-:0}"
  -e XAUTHORITY=/tmp/.Xauthority
  -e HOME=/sandbox-home
  -e XDG_RUNTIME_DIR=/tmp/xdg-runtime
  -e "AI_SANDBOX_MODE=$cmd"
  -e "AI_SANDBOX_FLAKE=${flake_arg:-}"
  -e "AI_SANDBOX_THEME=$theme"
  -v /tmp/.X11-unix:/tmp/.X11-unix:ro
  -v "$xauth_file:/tmp/.Xauthority:ro"
  -v "$workspace:/workspace:Z"
  -v "$HOME_VOLUME:/sandbox-home:Z,U"
  -v "$NIX_VOLUME:/nix:Z,U"
  --device /dev/dri
)

network_args=()
if [[ "$NETWORK_MODE" == "host" ]]; then
  network_args=(--network host)
fi

run_detached() {
  podman run --rm -d \
    "${common_args[@]}" \
    "${network_args[@]}" \
    "${dbus_args[@]}" \
    "$IMAGE" >/dev/null
  echo "Started $container_name"
}

run_interactive() {
  podman run --rm -it \
    "${common_args[@]}" \
    "${network_args[@]}" \
    "${dbus_args[@]}" \
    "$IMAGE"
}

case "$cmd" in
  start) run_detached ;;
  shell|warm) run_interactive ;;
  *) usage >&2; exit 1 ;;
esac
